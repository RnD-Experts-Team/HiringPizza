{
    "openapi": "3.1.0",
    "info": {
        "title": "HiringPizza Workforce API",
        "version": "1.1.0",
        "description": "Workflow-first API for workforce management. Employee operations are store-scoped by store number. Global catalog endpoints are not store-scoped."
    },
    "servers": [
        {
            "url": "/api"
        }
    ],
    "tags": [{ "name": "Employee Workflow" }, { "name": "Reference Catalog" }],
    "paths": {
        "/v1/reference-catalog": {
            "get": {
                "tags": ["Reference Catalog"],
                "summary": "Read global reference catalog",
                "responses": {
                    "200": {
                        "description": "Catalog payload",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ReferenceCatalogResponse"
                                },
                                "example": {
                                    "data": {
                                        "positions": [
                                            {
                                                "id": 1,
                                                "label": "Cook",
                                                "description": "Kitchen staff",
                                                "created_at": "2026-04-16T08:00:00.000000Z",
                                                "updated_at": "2026-04-16T08:00:00.000000Z"
                                            }
                                        ],
                                        "marital_statuses": [
                                            {
                                                "id": 1,
                                                "label": "Single",
                                                "description": null,
                                                "created_at": "2026-04-16T08:00:00.000000Z",
                                                "updated_at": "2026-04-16T08:00:00.000000Z"
                                            }
                                        ],
                                        "id_types": [
                                            {
                                                "id": 1,
                                                "label": "Driver License",
                                                "description": null,
                                                "created_at": "2026-04-16T08:00:00.000000Z",
                                                "updated_at": "2026-04-16T08:00:00.000000Z"
                                            }
                                        ],
                                        "attachment_types": [
                                            {
                                                "id": 1,
                                                "label": "Contract",
                                                "description": null,
                                                "created_at": "2026-04-16T08:00:00.000000Z",
                                                "updated_at": "2026-04-16T08:00:00.000000Z"
                                            }
                                        ],
                                        "tags": [
                                            {
                                                "id": 1,
                                                "label": "Onboarding",
                                                "created_at": "2026-04-16T08:00:00.000000Z",
                                                "updated_at": "2026-04-16T08:00:00.000000Z"
                                            }
                                        ]
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "put": {
                "tags": ["Reference Catalog"],
                "summary": "Sync global reference catalog",
                "description": "Single endpoint to create, update, and optionally delete catalog rows. For each item array: include `id` to update an existing row, omit `id` to create a new row.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ReferenceCatalogSyncRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Catalog synchronized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ReferenceCatalogSyncResponse"
                                },
                                "example": {
                                    "data": {
                                        "positions": [
                                            {
                                                "id": 2,
                                                "label": "Cashier",
                                                "description": null,
                                                "created_at": "2026-04-16T08:15:00.000000Z",
                                                "updated_at": "2026-04-16T08:15:00.000000Z"
                                            }
                                        ],
                                        "marital_statuses": [],
                                        "id_types": [],
                                        "attachment_types": [],
                                        "tags": []
                                    },
                                    "message": "Reference catalog synchronized."
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/v1/stores/{storeNumber}/employees": {
            "get": {
                "tags": ["Employee Workflow"],
                "summary": "List employees with advanced filtering",
                "description": "Store-scoped listing with broad filtering, sorting, and pagination options. `q` is the unified search field for names and SSN values (full or last 4).",
                "parameters": [
                    { "$ref": "#/components/parameters/storeNumber" },
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Unified search. Matches first/middle/last names and SSN digits (full or partial, including last 4).",
                        "schema": { "type": "string" }
                    },
                    {
                        "name": "employee_id",
                        "in": "query",
                        "schema": { "type": "integer" }
                    },
                    {
                        "name": "gender",
                        "in": "query",
                        "schema": { "$ref": "#/components/schemas/Gender" }
                    },
                    {
                        "name": "employment_type",
                        "in": "query",
                        "schema": {
                            "$ref": "#/components/schemas/EmploymentType"
                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "schema": {
                            "$ref": "#/components/schemas/EmployeeStatus"
                        }
                    },
                    {
                        "name": "status_in[]",
                        "in": "query",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/components/schemas/EmployeeStatus"
                            }
                        }
                    },
                    {
                        "name": "position_id",
                        "in": "query",
                        "schema": { "type": "integer" }
                    },
                    {
                        "name": "position_ids[]",
                        "in": "query",
                        "schema": {
                            "type": "array",
                            "items": { "type": "integer" }
                        }
                    },
                    {
                        "name": "marital_id",
                        "in": "query",
                        "schema": { "type": "integer" }
                    },
                    {
                        "name": "id_type_id",
                        "in": "query",
                        "schema": { "type": "integer" }
                    },
                    {
                        "name": "attachment_type_id",
                        "in": "query",
                        "schema": { "type": "integer" }
                    },
                    {
                        "name": "day_of_week",
                        "in": "query",
                        "schema": { "$ref": "#/components/schemas/DayOfWeek" }
                    },
                    {
                        "name": "shift_type",
                        "in": "query",
                        "schema": { "$ref": "#/components/schemas/ShiftType" }
                    },
                    {
                        "name": "base_pay_min",
                        "in": "query",
                        "schema": { "type": "number" }
                    },
                    {
                        "name": "base_pay_max",
                        "in": "query",
                        "schema": { "type": "number" }
                    },
                    {
                        "name": "performance_pay_min",
                        "in": "query",
                        "schema": { "type": "number" }
                    },
                    {
                        "name": "performance_pay_max",
                        "in": "query",
                        "schema": { "type": "number" }
                    },
                    {
                        "name": "effective_pay_from",
                        "in": "query",
                        "schema": { "type": "string", "format": "date" }
                    },
                    {
                        "name": "effective_pay_to",
                        "in": "query",
                        "schema": { "type": "string", "format": "date" }
                    },
                    {
                        "name": "birth_from",
                        "in": "query",
                        "schema": { "type": "string", "format": "date" }
                    },
                    {
                        "name": "birth_to",
                        "in": "query",
                        "schema": { "type": "string", "format": "date" }
                    },
                    {
                        "name": "race",
                        "in": "query",
                        "schema": { "$ref": "#/components/schemas/Race" }
                    },
                    {
                        "name": "religion",
                        "in": "query",
                        "schema": { "$ref": "#/components/schemas/Religion" }
                    },
                    {
                        "name": "account_type",
                        "in": "query",
                        "schema": { "$ref": "#/components/schemas/AccountType" }
                    },
                    {
                        "name": "has_primary_email",
                        "in": "query",
                        "schema": { "type": "boolean" }
                    },
                    {
                        "name": "has_primary_phone",
                        "in": "query",
                        "schema": { "type": "boolean" }
                    },
                    {
                        "name": "is_active",
                        "in": "query",
                        "schema": { "type": "boolean" }
                    },
                    {
                        "name": "created_from",
                        "in": "query",
                        "schema": { "type": "string", "format": "date" }
                    },
                    {
                        "name": "created_to",
                        "in": "query",
                        "schema": { "type": "string", "format": "date" }
                    },
                    {
                        "name": "updated_from",
                        "in": "query",
                        "schema": { "type": "string", "format": "date" }
                    },
                    {
                        "name": "updated_to",
                        "in": "query",
                        "schema": { "type": "string", "format": "date" }
                    },
                    {
                        "name": "sort_by",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "id",
                                "first_name",
                                "last_name",
                                "created_at",
                                "updated_at",
                                "employment_type",
                                "gender"
                            ]
                        }
                    },
                    {
                        "name": "sort_dir",
                        "in": "query",
                        "schema": { "type": "string", "enum": ["asc", "desc"] }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 100
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "schema": { "type": "integer", "minimum": 1 }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated employees",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EmployeeIndexResponse"
                                },
                                "example": {
                                    "current_page": 1,
                                    "data": [
                                        {
                                            "id": 10,
                                            "first_name": "John",
                                            "middle_name": null,
                                            "last_name": "Doe",
                                            "gender": "male",
                                            "employment_type": "W2",
                                            "created_at": "2026-04-16T08:00:00.000000Z",
                                            "updated_at": "2026-04-16T08:00:00.000000Z",
                                            "status_histories": [],
                                            "pay_histories": [],
                                            "contacts": [],
                                            "addresses": [],
                                            "availability_days": [],
                                            "financial_infos": [],
                                            "ids": [],
                                            "obsession": null,
                                            "positions": [],
                                            "stores": [],
                                            "maritals": [],
                                            "attachments": []
                                        }
                                    ],
                                    "first_page_url": "http://localhost/api/v1/stores/NY001/employees?page=1",
                                    "from": 1,
                                    "last_page": 1,
                                    "last_page_url": "http://localhost/api/v1/stores/NY001/employees?page=1",
                                    "links": [],
                                    "next_page_url": null,
                                    "path": "http://localhost/api/v1/stores/NY001/employees",
                                    "per_page": 25,
                                    "prev_page_url": null,
                                    "to": 1,
                                    "total": 1
                                }
                            }
                        }
                    },
                    "404": { "description": "Store not found" }
                }
            },
            "post": {
                "tags": ["Employee Workflow"],
                "summary": "Create employee via full workflow payload",
                "parameters": [
                    { "$ref": "#/components/parameters/storeNumber" }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/EmployeeWorkflowRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Employee created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EmployeeWorkflowEnvelope"
                                }
                            }
                        }
                    },
                    "422": { "description": "Validation error" }
                }
            }
        },
        "/v1/stores/{storeNumber}/employees/{employee}": {
            "get": {
                "tags": ["Employee Workflow"],
                "summary": "Get full employee workflow view",
                "parameters": [
                    { "$ref": "#/components/parameters/storeNumber" },
                    { "$ref": "#/components/parameters/employee" }
                ],
                "responses": {
                    "200": {
                        "description": "Employee payload",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EmployeeWorkflowEnvelope"
                                }
                            }
                        }
                    },
                    "404": { "description": "Not found" }
                }
            },
            "put": {
                "tags": ["Employee Workflow"],
                "summary": "Update employee via full workflow payload",
                "parameters": [
                    { "$ref": "#/components/parameters/storeNumber" },
                    { "$ref": "#/components/parameters/employee" }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/EmployeeWorkflowRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Employee updated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EmployeeWorkflowEnvelope"
                                }
                            }
                        }
                    },
                    "422": { "description": "Validation error" }
                }
            },
            "delete": {
                "tags": ["Employee Workflow"],
                "summary": "Delete employee",
                "parameters": [
                    { "$ref": "#/components/parameters/storeNumber" },
                    { "$ref": "#/components/parameters/employee" }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["actor_user_id"],
                                "properties": {
                                    "actor_user_id": { "type": "integer" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "204": { "description": "Employee deleted" }
                }
            }
        },
        "/v1/stores/{storeNumber}/employees/{employee}/status": {
            "patch": {
                "tags": ["Employee Workflow"],
                "summary": "Change employee status",
                "parameters": [
                    { "$ref": "#/components/parameters/storeNumber" },
                    { "$ref": "#/components/parameters/employee" }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["actor_user_id", "status"],
                                "properties": {
                                    "actor_user_id": { "type": "integer" },
                                    "status": {
                                        "$ref": "#/components/schemas/EmployeeStatus"
                                    },
                                    "effective_date": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "notes": { "type": "string" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Status changed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EmployeeWorkflowEnvelope"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "parameters": {
            "storeNumber": {
                "name": "storeNumber",
                "in": "path",
                "required": true,
                "schema": { "type": "string" },
                "description": "Store number identifier used for scoping employee workflow routes."
            },
            "employee": {
                "name": "employee",
                "in": "path",
                "required": true,
                "schema": { "type": "integer" }
            }
        },
        "schemas": {
            "Gender": { "type": "string", "enum": ["male", "female"] },
            "EmploymentType": { "type": "string", "enum": ["W2", "1099"] },
            "EmployeeStatus": {
                "type": "string",
                "enum": ["hired", "resigned", "terminated", "rehired", "OJE"]
            },
            "DayOfWeek": {
                "type": "string",
                "enum": [
                    "sunday",
                    "monday",
                    "tuesday",
                    "wednesday",
                    "thursday",
                    "friday",
                    "saturday"
                ]
            },
            "ShiftType": { "type": "string", "enum": ["PM", "AM", "OP"] },
            "AccountType": {
                "type": "string",
                "enum": ["checking", "savings"]
            },
            "Religion": {
                "type": "string",
                "enum": [
                    "Christianity",
                    "Islam",
                    "Judaism",
                    "Buddhism",
                    "Hinduism",
                    "Other"
                ]
            },
            "Race": {
                "type": "string",
                "enum": [
                    "Caucasian",
                    "African American",
                    "Hispanic",
                    "Asian",
                    "Native American",
                    "Other"
                ]
            },
            "ReferenceCatalogSyncRequest": {
                "type": "object",
                "properties": {
                    "positions": {
                        "type": "array",
                        "description": "If an item has `id`, it updates that row. If `id` is omitted, a new row is created.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": { "type": "integer", "nullable": true },
                                "label": { "type": "string" },
                                "description": {
                                    "type": "string",
                                    "nullable": true
                                }
                            }
                        }
                    },
                    "position_delete_ids": {
                        "type": "array",
                        "items": { "type": "integer" }
                    },
                    "marital_statuses": {
                        "type": "array",
                        "description": "If an item has `id`, it updates that row. If `id` is omitted, a new row is created.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": { "type": "integer", "nullable": true },
                                "label": { "type": "string" },
                                "description": {
                                    "type": "string",
                                    "nullable": true
                                }
                            }
                        }
                    },
                    "marital_status_delete_ids": {
                        "type": "array",
                        "items": { "type": "integer" }
                    },
                    "id_types": {
                        "type": "array",
                        "description": "If an item has `id`, it updates that row. If `id` is omitted, a new row is created.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": { "type": "integer", "nullable": true },
                                "label": { "type": "string" },
                                "description": {
                                    "type": "string",
                                    "nullable": true
                                }
                            }
                        }
                    },
                    "id_type_delete_ids": {
                        "type": "array",
                        "items": { "type": "integer" }
                    },
                    "attachment_types": {
                        "type": "array",
                        "description": "If an item has `id`, it updates that row. If `id` is omitted, a new row is created.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": { "type": "integer", "nullable": true },
                                "label": { "type": "string" },
                                "description": {
                                    "type": "string",
                                    "nullable": true
                                }
                            }
                        }
                    },
                    "attachment_type_delete_ids": {
                        "type": "array",
                        "items": { "type": "integer" }
                    },
                    "tags": {
                        "type": "array",
                        "description": "If an item has `id`, it updates that row. If `id` is omitted, a new row is created.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": { "type": "integer", "nullable": true },
                                "label": { "type": "string" }
                            }
                        }
                    },
                    "tag_delete_ids": {
                        "type": "array",
                        "items": { "type": "integer" }
                    }
                }
            },
            "ReferenceCatalogResponse": {
                "type": "object",
                "properties": {
                    "data": {
                        "type": "object",
                        "properties": {
                            "positions": {
                                "type": "array",
                                "items": { "type": "object" }
                            },
                            "marital_statuses": {
                                "type": "array",
                                "items": { "type": "object" }
                            },
                            "id_types": {
                                "type": "array",
                                "items": { "type": "object" }
                            },
                            "attachment_types": {
                                "type": "array",
                                "items": { "type": "object" }
                            },
                            "tags": {
                                "type": "array",
                                "items": { "type": "object" }
                            }
                        }
                    }
                }
            },
            "ReferenceCatalogSyncResponse": {
                "type": "object",
                "properties": {
                    "data": {
                        "type": "object",
                        "properties": {
                            "positions": {
                                "type": "array",
                                "items": { "type": "object" }
                            },
                            "marital_statuses": {
                                "type": "array",
                                "items": { "type": "object" }
                            },
                            "id_types": {
                                "type": "array",
                                "items": { "type": "object" }
                            },
                            "attachment_types": {
                                "type": "array",
                                "items": { "type": "object" }
                            },
                            "tags": {
                                "type": "array",
                                "items": { "type": "object" }
                            }
                        }
                    },
                    "message": { "type": "string" }
                }
            },
            "EmployeeWorkflowRequest": {
                "type": "object",
                "required": ["actor_user_id"],
                "properties": {
                    "actor_user_id": { "type": "integer" },
                    "first_name": { "type": "string" },
                    "middle_name": { "type": "string", "nullable": true },
                    "last_name": { "type": "string" },
                    "gender": { "$ref": "#/components/schemas/Gender" },
                    "ssn": { "type": "string" },
                    "employment_type": {
                        "$ref": "#/components/schemas/EmploymentType"
                    },
                    "status_history": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "pay_history": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "contacts": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "addresses": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "availability": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "financial_info": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "employee_ids": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "obsession": { "type": "object", "nullable": true },
                    "positions": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "marital_history": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "attachments": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "store_assignments": {
                        "type": "array",
                        "items": { "type": "object" }
                    }
                }
            },
            "EmployeeWorkflowEntity": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer" },
                    "first_name": { "type": "string" },
                    "middle_name": { "type": "string", "nullable": true },
                    "last_name": { "type": "string" },
                    "gender": { "$ref": "#/components/schemas/Gender" },
                    "employment_type": {
                        "$ref": "#/components/schemas/EmploymentType"
                    },
                    "created_at": { "type": "string", "format": "date-time" },
                    "updated_at": { "type": "string", "format": "date-time" },
                    "status_histories": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "pay_histories": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "contacts": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "addresses": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "availability_days": {
                        "type": "array",
                        "items": { "type": "object" }
                    },
                    "financial_infos": {
                        "type": "array",
